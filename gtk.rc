# gtk.rc — configuration for tw-gtk extensions
#
# Include in ~/.taskrc with:
#   include ~/.task/config/gtk.rc
#
# Or just place at ~/.task/config/gtk.rc — tw-gtk.sh reads it directly.

# ── Window dimensions ─────────────────────────────────────────────────────────

# Task list window (gtk_pick, gtk_pick_multi)
gtk.list-width  = 900
gtk.list-height = 600

# Form window (gtk_form_add, gtk_form_modify)
gtk.form-width  = 520

# Context switcher window (gtk-context.sh)
gtk.context-width = 500

# Task info dialog (gtk_info)
gtk.info-width    = 520

# ── Task list display ─────────────────────────────────────────────────────────

# Window title
gtk.title = Taskwarrior

# Urgency threshold for amber highlight (no due date, just high urgency)
gtk.urgent-hi = 15

# ── Hook-aware mutations ──────────────────────────────────────────────────────

# Enable hook-aware mutations for done/start/stop/delete actions.
# on  → spawns a terminal so interactive hooks (hledger-add, subtask, annn)
#        get a /dev/tty; all on-modify hooks fire normally.
# off → fast hook-free path (rc.hooks=off); safe default.
gtk.hooks = off

# Terminal emulator to use when gtk.hooks=on.
# Must accept: terminal -e script-path
# Examples: xterm, xfce4-terminal, kitty, alacritty
# gtk.terminal = xterm

# ── Notifications (on-modify_gtk-notify.sh) ───────────────────────────────────

# Enable/disable popup notifications for done/start/stop  (on | off)
gtk.notify = on

# Popup display time in seconds
gtk.notify-timeout = 4
